<UserControl
    x:Class="BankDds.Wpf.Views.CustomersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BankDds.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="860"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="260" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Style="{StaticResource PageTitleStyle}"
            Text="Quản lý khách hàng" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <Button
                x:Name="Add"
                Content="Thêm mới"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                x:Name="Edit"
                Content="Sửa"
                Style="{StaticResource WarningButtonStyle}" />
            <Button
                x:Name="Delete"
                Content="Xóa"
                Style="{StaticResource DangerButtonStyle}" />
            <Button
                x:Name="Restore"
                Content="Phục hồi"
                Style="{StaticResource SuccessButtonStyle}" />
        </StackPanel>

        <DataGrid
            x:Name="Customers"
            Grid.Row="2"
            SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
            Style="{StaticResource StandardDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding CMND}"
                    Header="CMND" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding Ho}"
                    Header="Họ" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Ten}"
                    Header="Tên" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}"
                    Header="Ngày sinh" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding NgayCap, StringFormat=dd/MM/yyyy}"
                    Header="Ngày cấp" />
                <DataGridTextColumn
                    Width="3*"
                    Binding="{Binding DiaChi}"
                    Header="Địa chỉ" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding SODT}"
                    Header="SĐT" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Phai}"
                    Header="Phái" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding BranchDisplayName}"
                    Header="Chi nhánh" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding StatusText}"
                    Header="Trạng thái" />
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="2"
            Style="{StaticResource DetailPanelStyle}"
            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thông tin khách hàng" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="CMND:" />
                    <TextBox
                        Margin="0,0,0,12"
                        IsEnabled="{Binding SelectedCustomer, Converter={StaticResource NullToBoolConverter}}"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingCustomer.CMND, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Họ:" />
                            <TextBox
                                Margin="0,0,0,12"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Text="{Binding EditingCustomer.Ho, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Tên:" />
                            <TextBox
                                Margin="0,0,0,12"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Text="{Binding EditingCustomer.Ten, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Ngày sinh:" />
                            <DatePicker
                                MinHeight="32"
                                Margin="0,0,0,12"
                                Padding="10"
                                FontSize="14"
                                SelectedDate="{Binding EditingCustomer.NgaySinh}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Ngày cấp CMND:" />
                            <DatePicker
                                MinHeight="32"
                                Margin="0,0,0,12"
                                Padding="10"
                                FontSize="14"
                                SelectedDate="{Binding EditingCustomer.NgayCap}" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Địa chỉ:" />
                            <TextBox
                                Margin="0,0,0,12"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Text="{Binding EditingCustomer.DiaChi, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="SĐT:" />
                            <TextBox
                                Margin="0,0,0,12"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Text="{Binding EditingCustomer.SODT, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Phái:" />
                            <ComboBox
                                Margin="0,0,0,12"
                                SelectedValue="{Binding EditingCustomer.Phai}"
                                Style="{StaticResource StandardComboBoxStyle}">
                                <ComboBoxItem Content="Nam" />
                                <ComboBoxItem Content="Nữ" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Chi nhánh:" />
                    <TextBox
                        Margin="0,0,0,12"
                        Background="#F0F0F0"
                        IsReadOnly="True"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingCustomer.BranchDisplayName, Mode=OneWay}" />

                    <Border
                        Style="{StaticResource ValidationErrorPanelStyle}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="#8B0000"
                                Text="Vui lòng sửa các lỗi sau:" />
                            <TextBlock
                                Foreground="#8B0000"
                                Text="{Binding ErrorMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            x:Name="Save"
                            Content="Ghi khách hàng"
                            Style="{StaticResource SuccessButtonStyle}" />
                        <Button
                            x:Name="Cancel"
                            Margin="0"
                            Content="Thoát"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.RowSpan="2"
                Padding="20"
                Background="#F8F9FA"
                BorderBrush="#DEE2E6"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding HasAccountCustomer, Converter={StaticResource InvertedBoolToVis}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontStyle="Italic"
                    Foreground="#6C757D"
                    Text="Chọn khách hàng trong danh sách hoặc nhập CMND để tra cứu khách hàng toàn hệ thống rồi mở tài khoản tại chi nhánh đang đăng nhập." />
            </Border>

            <Border
                Grid.Row="0"
                Padding="15"
                Background="#F8F9FA"
                BorderBrush="#DEE2E6"
                BorderThickness="1"
                CornerRadius="5"
                Visibility="{Binding HasAccountCustomer, Converter={StaticResource BoolToVisConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock
                            Style="{StaticResource SectionTitleStyle}"
                            Margin="0,0,0,6"
                            Text="{Binding AccountContextTitle}" />
                        <TextBlock
                            FontSize="13"
                            Foreground="#666666"
                            Text="{Binding AccountContextSubtitle}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Tra cứu khách hàng mở tài khoản theo CMND:" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="AccountCustomerLookupCmnd"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                Style="{StaticResource StandardTextBoxStyle}" />
                            <Button
                                x:Name="LookupAccountCustomer"
                                Grid.Column="1"
                                Content="Tra cứu CMND"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="AddAccount"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Content="Mở tài khoản"
                                Style="{StaticResource PrimaryButtonStyle}" />
                            <Button
                                x:Name="CloseAccount"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Content="Đóng tài khoản"
                                Style="{StaticResource DangerButtonStyle}" />
                            <Button
                                x:Name="ReopenAccount"
                                Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                Content="Mở lại"
                                Style="{StaticResource SuccessButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid
                x:Name="CustomerAccounts"
                Grid.Row="1"
                Margin="0,10,0,0"
                SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                Style="{StaticResource StandardDataGridStyle}"
                Visibility="{Binding IsEditingAccount, Converter={StaticResource InvertedBoolToVis}}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding SOTK}"
                        Header="Số tài khoản" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding SODU, StringFormat=N0}"
                        Header="Số dư (VND)" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding BranchDisplayName}"
                        Header="Chi nhánh mở TK" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding NGAYMOTK, StringFormat=dd/MM/yyyy}"
                        Header="Ngày mở" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding StatusDisplay}"
                        Header="Trạng thái" />
                </DataGrid.Columns>
            </DataGrid>

            <Border
                Grid.Row="1"
                Margin="0,10,0,0"
                Style="{StaticResource DetailPanelStyle}"
                Visibility="{Binding IsEditingAccount, Converter={StaticResource BoolToVisConverter}}">
                <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Mở tài khoản" />

                        <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Số tài khoản:" />
                        <TextBox
                            Margin="0,0,0,12"
                            Background="#F0F0F0"
                            IsReadOnly="True"
                            Style="{StaticResource StandardTextBoxStyle}"
                            Text="{Binding EditingAccount.SOTK}" />

                        <TextBlock Style="{StaticResource StandardLabelStyle}" Text="CMND khách hàng:" />
                        <TextBox
                            Margin="0,0,0,12"
                            Background="#F0F0F0"
                            IsReadOnly="True"
                            Style="{StaticResource StandardTextBoxStyle}"
                            Text="{Binding EditingAccount.CMND}" />

                        <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Chi nhánh mở tài khoản:" />
                        <TextBox
                            Margin="0,0,0,12"
                            Background="#F0F0F0"
                            IsReadOnly="True"
                            Style="{StaticResource StandardTextBoxStyle}"
                            Text="{Binding AccountOpenBranchDisplayName, Mode=OneWay}" />

                        <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Ngày mở:" />
                        <TextBox
                            Margin="0,0,0,12"
                            Background="#F0F0F0"
                            IsReadOnly="True"
                            Style="{StaticResource StandardTextBoxStyle}"
                            Text="{Binding EditingAccount.NGAYMOTK, StringFormat=dd/MM/yyyy HH:mm}" />

                        <Border
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="#E7F3FF"
                            BorderBrush="#B8DAFF"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="13"
                                Foreground="#004085"
                                Text="Số dư ban đầu được cố định là 0 VND. Mọi thay đổi số dư chỉ thực hiện qua tab Giao dịch." />
                        </Border>

                        <Border
                            Style="{StaticResource ValidationErrorPanelStyle}"
                            Visibility="{Binding HasAccountError, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontWeight="SemiBold"
                                    Foreground="#8B0000"
                                    Text="Vui lòng sửa các lỗi sau:" />
                                <TextBlock
                                    Foreground="#8B0000"
                                    Text="{Binding AccountErrorMessage}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                x:Name="SaveAccount"
                                Content="Ghi tài khoản"
                                Style="{StaticResource SuccessButtonStyle}" />
                            <Button
                                x:Name="CancelAccount"
                                Margin="0"
                                Content="Thoát"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,8,0,0">
            <TextBlock
                Style="{StaticResource SuccessMessageStyle}"
                Text="{Binding SuccessMessage}"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisConverter}}" />
            <TextBlock
                x:Name="ErrorMessage"
                Style="{StaticResource ErrorMessageStyle}"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}" />
        </StackPanel>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="5"
            Style="{StaticResource LoadingOverlayStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource LoadingSpinnerStyle}" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="Đang tải..." />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
