<UserControl
    x:Class="BankDds.Wpf.Views.CustomerLookupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Primary button style -->
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="20" Padding="24" Background="White" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="10"
                Direction="270"
                Opacity="0.1"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>

        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                <TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#0078D7"
                    Text="🔍 Tra cứu khách hàng toàn hệ thống" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="13"
                    Foreground="#888"
                    Text="Tìm kiếm khách hàng trên CSDL tra cứu (NGANHANG) — dữ liệu từ tất cả chi nhánh." />
            </StackPanel>

            <!-- Search bar -->
            <Border
                DockPanel.Dock="Top"
                Margin="0,0,0,16"
                Padding="16"
                Background="#F8F9FA"
                CornerRadius="6">
                <StackPanel>
                    <!-- Radio buttons for search mode -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton
                            Content="Tìm theo CMND (chính xác)"
                            IsChecked="{Binding SearchByCmnd, Mode=TwoWay}"
                            FontSize="13"
                            Margin="0,0,20,0" />
                        <RadioButton
                            Content="Tìm theo họ tên (gần đúng)"
                            IsChecked="{Binding SearchByName, Mode=TwoWay}"
                            FontSize="13" />
                    </StackPanel>

                    <!-- Search input + button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="SearchText"
                            Grid.Column="0"
                            Padding="8,6"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button
                            x:Name="Search"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Content="Tra cứu"
                            Style="{StaticResource SearchButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <TextBlock
                x:Name="StatusMessage"
                DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                FontSize="13"
                Foreground="#666" />

            <!-- Results grid -->
            <DataGrid
                x:Name="Results"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="#F5F8FC"
                RowHeight="32"
                FontSize="13"
                BorderThickness="1"
                BorderBrush="#DDD">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CMND" Binding="{Binding CMND}" Width="120" />
                    <DataGridTextColumn Header="Họ" Binding="{Binding Ho}" Width="120" />
                    <DataGridTextColumn Header="Tên" Binding="{Binding Ten}" Width="100" />
                    <DataGridTextColumn Header="Phái" Binding="{Binding Phai}" Width="60" />
                    <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh, StringFormat=\{0:dd/MM/yyyy\}}" Width="100" />
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding SODT}" Width="110" />
                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*" />
                    <DataGridTextColumn Header="Chi nhánh" Binding="{Binding MaCN}" Width="100" />
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
