<UserControl
    x:Class="BankDds.Wpf.Views.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BankDds.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
        <converters:UserGroupDisplayConverter x:Key="UserGroupDisplayConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock
                Style="{StaticResource PageTitleStyle}"
                Text="{Binding PageTitle}" />
            <TextBlock
                FontSize="13"
                Foreground="#666666"
                Text="{Binding PageSubtitle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            Orientation="Horizontal">
            <Button
                x:Name="Add"
                Content="Thêm người dùng"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                x:Name="Edit"
                Content="Sửa"
                Style="{StaticResource WarningButtonStyle}"
                Visibility="{Binding ShowBankAdminActions, Converter={StaticResource BoolToVisConverter}}" />
            <Button
                x:Name="Delete"
                Content="Xóa login"
                Style="{StaticResource DangerButtonStyle}"
                Visibility="{Binding ShowBankAdminActions, Converter={StaticResource BoolToVisConverter}}" />
        </StackPanel>

        <DataGrid
            x:Name="Users"
            Grid.Row="2"
            SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
            Style="{StaticResource StandardDataGridStyle}"
            Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVis}}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TrangThaiXoa}" Value="1">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="FontStyle" Value="Italic" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*" Binding="{Binding Username}" Header="Tên đăng nhập" />
                <DataGridTextColumn Width="2*" Binding="{Binding UserGroup, Converter={StaticResource UserGroupDisplayConverter}}" Header="Vai trò" />
                <DataGridTextColumn Width="2*" Binding="{Binding DefaultBranchDisplayName}" Header="Chi nhánh" />
                <DataGridTextColumn Width="2*" Binding="{Binding EmployeeId}" Header="Mã NV" />
                <DataGridTextColumn Width="2*" Binding="{Binding CustomerCMND}" Header="CMND KH" />
                <DataGridTextColumn Width="*" Binding="{Binding StatusText}" Header="Trạng thái" />
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="2"
            Style="{StaticResource DetailPanelStyle}"
            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Tên đăng nhập:" />
                    <TextBox
                        Margin="0,0,0,12"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.Username, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Mật khẩu mới:" />
                    <PasswordBox
                        x:Name="NewPasswordBox"
                        Margin="0,0,0,12"
                        PasswordChanged="OnNewPasswordChanged"
                        Style="{StaticResource StandardPasswordBoxStyle}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Xác nhận mật khẩu:" />
                    <PasswordBox
                        x:Name="ConfirmPasswordBox"
                        Margin="0,0,0,12"
                        PasswordChanged="OnConfirmPasswordChanged"
                        Style="{StaticResource StandardPasswordBoxStyle}" />

                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="12"
                        Text="{Binding PasswordValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#D32F2F" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPasswordValid}" Value="True">
                                        <Setter Property="Foreground" Value="#388E3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Nhóm người dùng:" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding AvailableUserGroups}"
                        SelectedItem="{Binding SelectedEditingUserGroup, Mode=TwoWay}"
                        IsEnabled="{Binding CanChangeTargetUserGroup}"
                        Style="{StaticResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource UserGroupDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock
                        Style="{StaticResource StandardLabelStyle}"
                        Text="Mã nhân viên:"
                        Visibility="{Binding ShowEmployeeIdField, Converter={StaticResource BoolToVisConverter}}" />
                    <TextBox
                        Margin="0,0,0,12"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.EmployeeId, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding ShowEmployeeIdField, Converter={StaticResource BoolToVisConverter}}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Chi nhánh mặc định:" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding AvailableBranches}"
                        SelectedItem="{Binding EditingUser.DefaultBranch, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditDefaultBranch}"
                        Style="{StaticResource StandardComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource BranchDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock
                        Style="{StaticResource StandardLabelStyle}"
                        Text="CMND khách hàng:"
                        Visibility="{Binding ShowCustomerCmndField, Converter={StaticResource BoolToVisConverter}}" />
                    <TextBox
                        Margin="0,0,0,20"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.CustomerCMND, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding ShowCustomerCmndField, Converter={StaticResource BoolToVisConverter}}" />

                    <Border
                        Style="{StaticResource ValidationErrorPanelStyle}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="#8B0000"
                                Text="Vui lòng sửa các lỗi sau:" />
                            <TextBlock
                                Foreground="#8B0000"
                                Text="{Binding ErrorMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            x:Name="Save"
                            Content="Ghi"
                            Style="{StaticResource SuccessButtonStyle}" />
                        <Button
                            x:Name="Cancel"
                            Margin="0"
                            Content="Thoát"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock
                Style="{StaticResource SuccessMessageStyle}"
                Text="{Binding SuccessMessage}"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisConverter}}" />
            <TextBlock
                x:Name="ErrorMessage"
                Style="{StaticResource ErrorMessageStyle}" />
        </StackPanel>

        <Grid Grid.Row="0" Grid.RowSpan="4" Style="{StaticResource LoadingOverlayStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource LoadingSpinnerStyle}" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="Đang tải..." />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
