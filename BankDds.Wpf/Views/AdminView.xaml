<UserControl
    x:Class="BankDds.Wpf.Views.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BankDds.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    Background="White"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Style="{StaticResource PageTitleStyle}"
            Text="Quan tri Nguoi dung" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            Orientation="Horizontal">
            <Button
                x:Name="Add"
                Content="Them nguoi dung"
                Style="{StaticResource PrimaryButtonStyle}" />
            <Button
                x:Name="Edit"
                Content="Sua"
                Style="{StaticResource WarningButtonStyle}" />
            <Button
                x:Name="Delete"
                Content="Xoa login"
                Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>

        <DataGrid
            x:Name="Users"
            Grid.Row="2"
            SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
            Style="{StaticResource StandardDataGridStyle}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TrangThaiXoa}" Value="1">
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="FontStyle" Value="Italic" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Width="150" Binding="{Binding Username}" Header="Ten dang nhap" />
                <DataGridTextColumn Width="120" Binding="{Binding UserGroup}" Header="Vai tro" />
                <DataGridTextColumn Width="150" Binding="{Binding DefaultBranch}" Header="Chi nhanh" />
                <DataGridTextColumn Width="130" Binding="{Binding EmployeeId}" Header="Ma NV" />
                <DataGridTextColumn Width="150" Binding="{Binding CustomerCMND}" Header="CMND KH" />
                <DataGridTextColumn Width="*" Binding="{Binding StatusText}" Header="Trang thai" />
            </DataGrid.Columns>
        </DataGrid>

        <Border
            Grid.Row="2"
            Style="{StaticResource DetailPanelStyle}"
            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thong tin Nguoi dung" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Ten dang nhap:" />
                    <TextBox
                        Margin="0,0,0,12"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.Username, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Mat khau moi:" />
                    <PasswordBox
                        x:Name="NewPasswordBox"
                        Margin="0,0,0,12"
                        PasswordChanged="OnNewPasswordChanged"
                        Style="{StaticResource StandardPasswordBoxStyle}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Xac nhan mat khau:" />
                    <PasswordBox
                        x:Name="ConfirmPasswordBox"
                        Margin="0,0,0,12"
                        PasswordChanged="OnConfirmPasswordChanged"
                        Style="{StaticResource StandardPasswordBoxStyle}" />

                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="12"
                        Text="{Binding PasswordValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#D32F2F" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPasswordValid}" Value="True">
                                        <Setter Property="Foreground" Value="#388E3C" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Nhom nguoi dung:" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding AvailableUserGroups}"
                        SelectedItem="{Binding SelectedEditingUserGroup, Mode=TwoWay}"
                        IsEnabled="{Binding CanChangeTargetUserGroup}"
                        Style="{StaticResource StandardComboBoxStyle}" />

                    <TextBlock
                        Style="{StaticResource StandardLabelStyle}"
                        Text="Ma nhan vien (NVxxxxxxxx):"
                        Visibility="{Binding ShowEmployeeIdField, Converter={StaticResource BoolToVisConverter}}" />
                    <TextBox
                        Margin="0,0,0,12"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.EmployeeId, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding ShowEmployeeIdField, Converter={StaticResource BoolToVisConverter}}" />

                    <TextBlock Style="{StaticResource StandardLabelStyle}" Text="Chi nhanh mac dinh:" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding AvailableBranches}"
                        SelectedItem="{Binding EditingUser.DefaultBranch, Mode=TwoWay}"
                        IsEnabled="{Binding CanEditDefaultBranch}"
                        Style="{StaticResource StandardComboBoxStyle}" />

                    <TextBlock
                        Style="{StaticResource StandardLabelStyle}"
                        Text="CMND khach hang:"
                        Visibility="{Binding ShowCustomerCmndField, Converter={StaticResource BoolToVisConverter}}" />
                    <TextBox
                        Margin="0,0,0,20"
                        Style="{StaticResource StandardTextBoxStyle}"
                        Text="{Binding EditingUser.CustomerCMND, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding ShowCustomerCmndField, Converter={StaticResource BoolToVisConverter}}" />

                    <Border
                        Style="{StaticResource ValidationErrorPanelStyle}"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="#8B0000"
                                Text="Vui long sua cac loi sau:" />
                            <TextBlock
                                Foreground="#8B0000"
                                Text="{Binding ErrorMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            x:Name="Save"
                            Content="Ghi"
                            Style="{StaticResource SuccessButtonStyle}" />
                        <Button
                            x:Name="Cancel"
                            Margin="0"
                            Content="Thoat"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock
                Margin="0,0,0,5"
                FontWeight="SemiBold"
                Foreground="#388E3C"
                Text="{Binding SuccessMessage}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SuccessMessage.Length, FallbackValue=0}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock
                x:Name="ErrorMessage"
                Style="{StaticResource ErrorMessageStyle}" />
        </StackPanel>

        <Grid Grid.Row="0" Grid.RowSpan="4" Style="{StaticResource LoadingOverlayStyle}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource LoadingSpinnerStyle}" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="Dang tai..." />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
